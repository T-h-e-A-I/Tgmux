# Copy to .env, fill in, then: chmod 600 .env
TELEGRAM_BOT_TOKEN=123456789:AA...          # from @BotFather
TELEGRAM_OWNER_ID=0                         # your numeric Telegram user ID (@userinfobot)

PROJECTS_DIR=/root/projects                 # base dir for /ls /mkdir /new
# VM_HOST=                                  # public IP/hostname for /port URLs (auto-detected if empty)
# ANTHROPIC_API_KEY=                        # only needed for `/new <name> api` agents

# CLAUDE_BIN=claude
# PORT_MIN=3001
# PORT_MAX=3099
# POLL_INTERVAL=2.0                         # pane poll cadence (s)
# RELAY_MIN_INTERVAL=5.0                    # min gap between progress messages (s)
# IDLE_TIMEOUT=60                           # stable pane -> IDLE after this (s)
